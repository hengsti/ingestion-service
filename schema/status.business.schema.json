{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Canonical Status Message",
  "allOf": [
    { "$ref": "https://smarthome-ingest/base.schema.json" },
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "device_id": {},
        "device_class": {},
        "fw_version": {},
        "time_ms": {},
        "time_iso": {},
        "time_valid": {},
        "ip": {
          "type": "string",
          "minLength": 1,
          "description": "Current IP address of the device"
        },
        "rssi": {
          "type": "integer",
          "description": "WiFi RSSI in dBm"
        },
        "uptime": {
          "type": "integer",
          "minimum": 0,
          "description": "Device uptime in seconds or milliseconds, depending on your convention"
        },
        "free_mem": {
          "type": "integer",
          "minimum": 0,
          "description": "Free memory on the device"
        },
        "ssid": {
          "type": "string",
          "description": "Connected WiFi SSID"
        }
      },
      "required": [
        "ip",
        "rssi",
        "uptime",
        "free_mem",
        "ssid"
      ]
    }
  ]
}