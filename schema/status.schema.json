{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Status Message",
  "allOf": [
    {
      "$ref": "https://smarthome-ingest/base.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "ip": {
          "type": "string",
          "description": "IP address of the device on the local network"
        },
        "rssi": {
          "type": "integer",
          "description": "Received Signal Strength Indicator in dBm"
        },
        "uptime": {
          "type": "integer",
          "description": "Device uptime in seconds"
        },
        "free_mem": {
          "type": "integer",
          "description": "Free memory in bytes"
        },
        "ssid": {
          "type": "string",
          "description": "Connected WiFi SSID"
        }
      },
      "required": [
        "ip",
        "rssi"
      ]
    }
  ]
}