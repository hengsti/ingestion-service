{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "device_id": {
      "type": "string",
      "description": "Unique identifier for the device"
    },
    "room": {
      "type": "string",
      "description": "Room where the device is located"
    },
    "device_class": {
      "type": "string",
      "description": "Device class or model"
    },
    "fw_version": {
      "type": "string",
      "description": "Firmware version running on the device"
    },
    "time_ms": {
      "type": "integer",
      "description": "Timestamp in milliseconds"
    },
    "time_iso": {
      "type": "string",
      "description": "Timestamp in ISO 8601 format"
    },
    "time_valid": {
      "type": "boolean",
      "description": "Indicates if the timestamp is valid and synchronized with real time"
    },
    "data": {
      "type": "object",
      "properties": {
        "temp_c": {
          "type": "number",
          "description": "Temperature in Celsius"
        },
        "rel_hum_perc": {
          "type": "number",
          "description": "Relative Humidity in percent"
        },
        "pressure_hpa": {
          "type": "number",
          "description": "Atmospheric pressure in hPa"
        },
        "gas_ohm": {
          "type": "number",
          "description": "Gas resistance in Ohms"
        },
        "iaq_score": {
          "type": "number",
          "description": "Indoor Air Quality index derived from gas_ohm"
        },
        "iaq_text": {
          "type": "string",
          "description": "Indoor Air Quality description"
        },
        "dew_point_c": {
          "type": "number",
          "description": "Dew point temperature in Celsius"
        },
        "heat_index_c": {
          "type": "number",
          "description": "Heat index temperature derived from temp_c and rel_hum_perc"
        },
        "altitude_m": {
          "type": "number",
          "description": "Approximate altitude in meters"
        }
      },
      "required": [
        "temp_c",
        "rel_hum_perc",
        "pressure_hpa",
        "gas_ohm",
        "iaq_score",
        "iaq_text",
        "dew_point_c",
        "heat_index_c",
        "altitude_m"
      ]
    },
    "status": {
      "type": "object",
      "properties": {
        "uptime": {
          "type": "integer",
          "description": "Device uptime in seconds"
        },
        "free_mem": {
          "type": "integer",
          "description": "Free memory in bytes"
        },
        "rssi": {
          "type": "integer",
          "description": "WiFi signal strength in dBm"
        },
        "ssid": {
          "type": "string",
          "description": "Connected WiFi SSID"
        }
      },
      "required": [
        "uptime",
        "free_mem",
        "rssi",
        "ssid"
      ]
    }
  },
  "required": [
    "device_id",
    "room",
    "device_class",
    "fw_version",
    "time_ms",
    "time_iso",
    "time_valid",
    "data",
    "status"
  ]
}