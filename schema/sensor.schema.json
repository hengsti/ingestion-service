{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sensor Message",
  "allOf": [
    { "$ref": "https://smarthome-ingest/base.schema.json" },
    {
      "type": "object",
      "properties": {
        "room": {
          "type": "string",
          "description": "Room where the device is located"
        },
        "data": {
          "type": "object",
          "properties": {
            "temp_c": {
              "type": "number",
              "description": "Temperature in Celsius"
            },
            "rel_hum_perc": {
              "type": "number",
              "description": "Relative Humidity in percent"
            },
            "pressure_hpa": {
              "type": "number",
              "description": "Atmospheric pressure in hPa"
            },
            "gas_ohm": {
              "type": "number",
              "description": "Gas resistance in Ohms"
            },
            "altitude_m": {
              "type": "number",
              "description": "Approximate altitude in meters"
            }
          },
          "required": [
            "temp_c",
            "rel_hum_perc",
            "pressure_hpa",
            "gas_ohm",
            "altitude_m"
          ]
        }
      },
      "required": [
        "room",
        "data"
      ]
    }
  ]
}