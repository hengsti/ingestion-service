{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Canonical Sensor Message",
  "allOf": [
    { "$ref": "https://smarthome-ingest/base.schema.json" },
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "device_id": {},
        "device_class": {},
        "fw_version": {},
        "time_ms": {},
        "time_iso": {},
        "time_valid": {},
        "room": {
          "type": "string",
          "minLength": 1,
          "description": "Room where the device is located"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "temp_c": {
              "type": "number",
              "description": "Temperature in Celsius"
            },
            "rel_hum_perc": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 100,
              "description": "Relative humidity in percent"
            },
            "pressure_hpa": {
              "type": "number",
              "description": "Atmospheric pressure in hPa"
            },
            "gas_ohm": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Gas resistance in Ohms"
            },
            "iaq_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Indoor air quality score after transform"
            },
            "iaq_text": {
              "type": "string",
              "minLength": 1,
              "description": "Human-readable air quality classification"
            },
            "dew_point_c": {
              "type": "number",
              "description": "Calculated dew point in Celsius"
            },
            "heat_index_c": {
              "type": "number",
              "description": "Calculated heat index in Celsius"
            },
            "altitude_m": {
              "type": "number",
              "description": "Approximate altitude in meters"
            }
          },
          "required": [
            "temp_c",
            "rel_hum_perc",
            "pressure_hpa",
            "gas_ohm",
            "iaq_score",
            "iaq_text",
            "dew_point_c",
            "heat_index_c",
            "altitude_m"
          ]
        }
      },
      "required": [
        "room",
        "data"
      ]
    }
  ]
}